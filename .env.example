# ---- SAJ portal account (dedicated monitoring account — never logged into by hand) ----
SAJ_USER=operation01
SAJ_PASS=change-me

# ---- database ----
# PROD (recommended on Railway): direct connection. In Railway, add a variable
# reference to your Postgres service so this stays in sync:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=

# Fallback only (used when DATABASE_URL is empty): the HTTP SQL proxy.
# The proxy token is short-lived and expires — prefer DATABASE_URL for prod.
PG_PROXY_URL=https://pg-proxy-production.up.railway.app/api/sql
PG_PROXY_TOKEN=
PG_DB_NAME=prod_main

# ---- API protection ----
# If set, every /fetch call must send ?token=... or header X-Trigger-Token: ...
TRIGGER_TOKEN=

# max days of history a single request may backfill
MAX_DAYS=14

# per-visit freshness gate: skip the SAJ pull if this device was fetched within
# this many seconds (data is 5-min cadence). ?force=true overrides.
VISIT_FRESH_SECONDS=240

# ---- nightly sweep (sync_all.py, run via Railway Cron at 23:00 MYT) ----
SAJ_REQ_INTERVAL=1.0   # seconds between requests (throttle)
SAJ_REQ_JITTER=0.3
SYNC_DAYS=1            # days back to pull (1 = today only)
# SYNC_LIMIT=10        # cap device count for testing

# ---- device model + image backfill (backfill_device_info.py) ----
# Mirrors SAJ-cloud inverter images into our own R2 bucket and stores model info.
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=eternalgy-image
R2_PUBLIC_BASE=https://<pub-id>.r2.dev
R2_PREFIX=saj-inverter
# LIMIT=5              # cap device count for testing
